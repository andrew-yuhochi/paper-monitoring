# Paper Monitoring — Environment Configuration
# Copy to .env and adjust values as needed

# Ollama
PM_OLLAMA_HOST=http://localhost:11434
PM_OLLAMA_MODEL=qwen2.5:7b

# Pre-filter tuning
PM_PREFILTER_TOP_N=100
PM_PREFILTER_UPVOTE_WEIGHT=2.0

# Logging
PM_LOG_LEVEL=INFO

# Git access (GitHub Personal Access Token with repo scope)
GIT_TOKEN=your_github_pat_here